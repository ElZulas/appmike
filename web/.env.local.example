# Copia a web/.env.local (no subas secretos a git):
#   cp .env.local.example .env.local
#
# Guía: docs/DESPLIEGUE_RENDER_VERCEL.md

# API local o pública (Render)
API_BASE_URL=http://127.0.0.1:4000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:4000

# PayPal (mismo Client ID que api/.env — es público en el navegador)
# developer.paypal.com → Sandbox → tu app → Client ID
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
NEXT_PUBLIC_PAYPAL_MODE=sandbox

# Firebase web — Firebase Console → appmike → Configuración → Tus apps → Web
# Icono </> o "Agregar app" si no existe
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=appmike.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=appmike
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=appmike.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
