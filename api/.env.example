# Copia este archivo a api/.env (no se sube a git):
#   cp .env.example .env
#
# Guía completa: docs/DESPLIEGUE_RENDER_VERCEL.md

PORT=4000
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
WEB_PUBLIC_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000

# --- Firebase Admin (catálogo en Firestore, pedidos, usuarios) ---
# Opción A — local: JSON de cuenta de servicio en api/
#   Firebase Console → appmike → Configuración (⚙) → Cuentas de servicio → Generar nueva clave privada
GOOGLE_APPLICATION_CREDENTIALS=./appmike-firebase-adminsdk-xxxxx.json

# Opción B — Render / producción (recomendado en la nube; no subas el JSON):
#   Abre el JSON descargado y copia project_id, client_email, private_key
#   O ejecuta: npm run env:firebase
# FIREBASE_PROJECT_ID=appmike
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@appmike.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- PayPal Sandbox (opcional hasta activar pagos) ---
# https://developer.paypal.com/dashboard/applications → pestaña Sandbox → tu app
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
# PAYPAL_TRUST_CLIENT_CAPTURE=true

# Solo desarrollo: marcar pedido pagado sin PayPal
# ALLOW_MANUAL_PAY=true
